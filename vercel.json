{
  "version": 2,
  "builds": [
    {
      "src": "frontend/src/App.tsx",
      "use": "@vercel/node"
    }

  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/src/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "frontend/src/App.tsx"
    }
  ]
}